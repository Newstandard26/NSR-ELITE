// NSR Field Canvassing App — Prisma schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  REP
}

model User {
  id           String                @id @default(cuid())
  name         String
  email        String                @unique
  // Hashed password for NextAuth credentials login.
  passwordHash String?
  role         Role                  @default(REP)
  acculynxId   String?
  isActive     Boolean               @default(true)
  // Timestamp of the user's most recent app activity (login or usage ping).
  lastLoginAt  DateTime?
  // Manager-set targets for gamification.
  dailyTarget  Int?
  weeklyTarget Int?
  leads        Lead[]
  appointments Appointment[]
  locations    RepLocation[]
  territories  TerritoryAssignment[]
  notes        Note[]
  notifications Notification[]
  loginEvents  LoginEvent[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model DispositionStatus {
  id           String   @id @default(cuid())
  label        String
  // Short code (max 4 chars) shown on map pins.
  abbreviation String?
  color        String // hex e.g. "#51C5F4"
  icon         String // emoji e.g. "🔵"
  // SalesRabbit-style pipeline stage this status maps to.
  pipelineStage String?
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  sortOrder    Int
  leads        Lead[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Territory {
  id          String                @id @default(cuid())
  name        String
  geoJson     Json
  color       String
  status      String                @default("ACTIVE") // ACTIVE, COMPLETED, PENDING
  assignments TerritoryAssignment[]
  leads       Lead[]
  createdAt   DateTime              @default(now())
}

model TerritoryAssignment {
  id           String    @id @default(cuid())
  territory    Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  territoryId  String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?

  @@index([territoryId])
  @@index([userId])
}

model Lead {
  id                  String             @id @default(cuid())
  address             String
  city                String
  state               String
  zip                 String
  lat                 Float
  lng                 Float
  ownerName           String?
  phone               String?
  email               String?
  roofAge             Int?
  insuranceCompany    String?
  dispositionStatus   DispositionStatus? @relation(fields: [dispositionStatusId], references: [id])
  dispositionStatusId String?
  dispositionAt       DateTime?
  notes               Note[]
  photos              Photo[]
  rep                 User?              @relation(fields: [repId], references: [id])
  repId               String?
  territory           Territory?         @relation(fields: [territoryId], references: [id])
  territoryId         String?
  acculynxJobId       String?
  acculynxContactId   String?
  acculynxJobUrl      String?
  acculynxStatus      String?
  acculynxPushedAt    DateTime?
  // Property data enrichment (ATTOM etc.), cached per address in PropertyRecord.
  propertyRecord      PropertyRecord?    @relation(fields: [propertyRecordId], references: [id])
  propertyRecordId    String?
  enrichedAt          DateTime?
  appointments        Appointment[]
  activities          LeadActivity[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([dispositionStatusId])
  @@index([repId])
  @@index([territoryId])
  @@index([propertyRecordId])
}

model LeadActivity {
  id          String   @id @default(cuid())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId      String
  // lead_created, status_changed, note_added, rep_changed, acculynx_push,
  // acculynx_milestone, lead_imported
  type        String
  description String
  actor       String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  author    String
  authorUser User?   @relation(fields: [authorUserId], references: [id])
  authorUserId String?
  createdAt DateTime @default(now())

  @@index([leadId])
}

model Photo {
  id        String   @id @default(cuid())
  url       String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  createdAt DateTime @default(now())

  @@index([leadId])
}

model Appointment {
  id          String   @id @default(cuid())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId      String
  rep         User     @relation(fields: [repId], references: [id])
  repId       String
  scheduledAt DateTime
  type        String // INSPECTION, ESTIMATE, FOLLOWUP
  durationMinutes Int   @default(60)
  notes       String?
  status      String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  createdAt   DateTime @default(now())

  @@index([repId])
  @@index([leadId])
  @@index([scheduledAt])
}

// Singleton workspace/branding settings.
model WorkspaceSettings {
  id         String   @id @default("default")
  brandColor String?
  logoUrl    String?
  updatedAt  DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String
  message   String
  leadId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

// CSV import history.
model ImportLog {
  id         String   @id @default(cuid())
  filename   String
  total      Int
  success    Int
  errors     Int
  importedBy String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// AccuLynx sync audit log (pushes out + webhooks in).
model SyncLog {
  id           String   @id @default(cuid())
  leadId       String?
  direction    String   // to_acculynx | from_acculynx
  event        String   // Lead Pushed, Milestone Updated, Push Failed, ...
  status       String   // success | failed | pending
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([status])
}

// Singleton integration settings (single-workspace for now).
model IntegrationSettings {
  id                   String   @id @default("default")
  acculynxLeadSourceId String?
  // Array of disposition status ids that trigger an AccuLynx push.
  triggerStatusIds     Json?
  // Map of AccuLynx milestone name -> disposition status id.
  milestoneMap         Json?
  updatedAt            DateTime @updatedAt
}

// Cached property-data enrichment, keyed by normalized address so multiple
// leads at the same parcel (and re-taps) reuse one paid lookup. `raw` keeps the
// full provider payload; the parsed columns power the UI.
model PropertyRecord {
  id                 String    @id @default(cuid())
  // Lowercased "address, city, state zip" used as the cache key.
  normalizedAddress  String    @unique
  source             String    // mock | attom
  // Ownership
  ownerName          String?
  ownerOccupied      Boolean?
  mailingAddress     String?
  // Characteristics
  yearBuilt          Int?
  sqft               Int?
  beds               Int?
  baths              Float?
  lotSizeSqft        Int?
  // Value & sale
  lastSalePrice      Int?
  lastSaleDate       DateTime?
  assessedValue      Int?
  avmValue           Int?
  avmLow             Int?
  avmHigh            Int?
  estimatedEquity    Int?
  mortgageBalanceEst Int?
  // Soft qualifier (modeled marketing data — NOT an FCRA credit report)
  estimatedIncomeBand String?
  // Contact append (skip trace). phones: [{ number, type, dnc }]; emails: string[]
  phones             Json?
  emails             Json?
  raw                Json?
  fetchedAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  leads              Lead[]
}

// One row per successful login, for usage/adoption analytics.
model LoginEvent {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model RepLocation {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  lat       Float
  lng       Float
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
}
