# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/nsr_canvassing?schema=public"

# --- NextAuth ---
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# --- AccuLynx CRM ---
ACCULYNX_API_KEY=""
ACCULYNX_BASE_URL="https://api.acculynx.com/api/v2"
# Optional shared secret to validate inbound AccuLynx webhooks
ACCULYNX_WEBHOOK_SECRET=""

# --- Mapbox ---
# Server-side token (kept private)
MAPBOX_TOKEN=""
# Public token used by the browser map (scope it to your domains)
NEXT_PUBLIC_MAPBOX_TOKEN=""

# --- Google Places (address autocomplete + geocoding) ---
GOOGLE_PLACES_API_KEY=""

# --- Cloudinary (lead photo storage) ---
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# --- Email (user invites via SMTP, e.g. Gmail/Workspace App Password) ---
# Leave SMTP_USER/SMTP_PASSWORD blank to "mock" emails (logged, not sent).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASSWORD=""
# Display name + from address (must be the SMTP user or a verified "send as" alias).
MAIL_FROM="NSR Elite <info@newstandardrestoration.com>"

# --- Property data enrichment (tap-a-house owner/value/equity + skip trace) ---
# Master on/off switch for the "Pull property data" feature (server).
PROPERTY_ENRICHMENT_ENABLED="false"
# Must also be set for the browser to render the button. Keep in sync with above.
NEXT_PUBLIC_PROPERTY_ENRICHMENT_ENABLED="false"
# Provider: "mock" (sample data), "attom", or "batchdata" (property + skip-traced
# contacts/income). Defaults to mock.
PROPERTY_DATA_PROVIDER="mock"
# ATTOM real-time property API key (required when PROPERTY_DATA_PROVIDER=attom).
ATTOM_API_KEY=""
# BatchData (BatchLeads) API bearer token (required when PROPERTY_DATA_PROVIDER=batchdata).
BATCHDATA_API_KEY=""
# Optional override for BatchData base URL.
BATCHDATA_BASE_URL="https://api.batchdata.com/api/v1"
