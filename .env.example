# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/nsr_canvassing?schema=public"

# --- NextAuth ---
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# --- AccuLynx CRM ---
ACCULYNX_API_KEY=""
ACCULYNX_BASE_URL="https://api.acculynx.com/api/v2"
# Optional shared secret to validate inbound AccuLynx webhooks
ACCULYNX_WEBHOOK_SECRET=""

# --- Mapbox ---
# Server-side token (kept private)
MAPBOX_TOKEN=""
# Public token used by the browser map (scope it to your domains)
NEXT_PUBLIC_MAPBOX_TOKEN=""

# --- Google Places (address autocomplete + geocoding) ---
GOOGLE_PLACES_API_KEY=""

# --- Cloudinary (lead photo storage) ---
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# --- Property data enrichment (tap-a-house owner/value/equity + skip trace) ---
# Master on/off switch for the "Pull property data" feature (server).
PROPERTY_ENRICHMENT_ENABLED="false"
# Must also be set for the browser to render the button. Keep in sync with above.
NEXT_PUBLIC_PROPERTY_ENRICHMENT_ENABLED="false"
# Provider: "mock" (deterministic sample data) or "attom" (live). Defaults to mock.
PROPERTY_DATA_PROVIDER="mock"
# ATTOM real-time property API key (required when PROPERTY_DATA_PROVIDER=attom).
ATTOM_API_KEY=""
